UC_PublishPaper ..> UC_AddPaperToJournal : <<include>>
UC_PublishPaper ..> UC_GenerateResearchAnnouncement : <<include>>
UC_PublishPaper ..> UC_NotifySubscribers : <<include>>

UC_GetCitation ..> UC_PublishPaper : <<extend>>

UC_PrintOwnPapers ..> UC_SortPapers : <<include>>
UC_PrintAllPapers ..> UC_SortPapers : <<include>>

