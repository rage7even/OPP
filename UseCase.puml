UC_ManageNews ..> UC_CreateResearchNews : <<include>>
UC_CreateResearchNews ..> UC_PinResearchNews : <<include>>

UC_GenerateResearchAnnouncement ..> UC_CreateResearchNews : <<include>>
UC_GenerateResearchAnnouncement ..> UC_PinResearchNews : <<include>>

UC_GenerateTopResearcherNews ..> UC_FindTopResearcher : <<include>>
UC_GenerateTopResearcherNews ..> UC_CreateResearchNews : <<include>>
UC_GenerateTopResearcherNews ..> UC_PinResearchNews : <<include>>

