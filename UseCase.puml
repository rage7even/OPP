UC_ManageUsers ..> UC_AddUser : <<include>>
UC_ManageUsers ..> UC_UpdateUser : <<include>>
UC_ManageUsers ..> UC_RemoveUser : <<include>>

' ===================== INCLUDE / EXTEND: TECH SUPPORT =====================

UC_ViewSupportRequests ..> UC_MarkViewed : <<include>>
UC_AcceptRequest ..> UC_ViewSupportRequests : <<include>>
UC_RejectRequest ..> UC_ViewSupportRequests : <<include>>
UC_MarkDone ..> UC_AcceptRequest : <<include>>

